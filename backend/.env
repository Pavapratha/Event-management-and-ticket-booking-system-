PORT=5000
MONGODB_URI=mongodb://localhost:27017/lycaon-auth
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# Frontend URL (for verification links)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# EMAIL CONFIGURATION - GMAIL SMTP WITH APP PASSWORD
# ============================================================================
# 
# IMPORTANT: You MUST use a Gmail App Password, NOT your actual Gmail password!
# 
# STEP 1: Enable 2-Step Verification
#   1. Go to https://myaccount.google.com/
#   2. Click "Security" in the left sidebar
#   3. Search for "2-Step Verification" and enable it
#
# STEP 2: Generate App Password
#   1. Go to https://myaccount.google.com/apppasswords
#   2. Select "Mail" from the dropdown
#   3. Select "Windows Computer" (or your device type)
#   4. Google will generate a 16-character password
#   5. Copy that password and paste it as SMTP_PASSWORD below (remove spaces)
#
# STEP 3: Update these environment variables
#   - SMTP_USER: Your full Gmail address
#   - SMTP_PASSWORD: The 16-character App Password from step 2
#
# ERROR 535 5.7.8 BadCredentials? 
#   → You're using your actual Gmail password instead of an App Password
#   → Follow the steps above to generate an App Password
# ============================================================================

# Gmail SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=pavithramathiyalagon@gmail.com
# ⚠️  REPLACE THIS WITH YOUR 16-CHARACTER GMAIL APP PASSWORD (NOT YOUR GMAIL PASSWORD)
# Example: if Google gives you "abcd efgh ijkl mnop", use "abcdefghijklmnop"
SMTP_PASSWORD=quimewurabdzdmvh
SMTP_FROM_EMAIL=noreply@eventmanagement.com
